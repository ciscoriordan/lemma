# Lemma Greek Dictionary generated files

# Generated dictionary directories
lemma_greek_*/

# Downloaded data files. Lemma redownloads from Kaikki on each run, so we
# never need to track the dump in git. There is no committed fallback file.
*.jsonl

# Sidecar metadata written next to downloaded Kaikki dumps
*.jsonl.meta

# Processed entries cache files
processed_entries_*.json

# Kindle Previewer log files
*.log

# macOS system files
.DS_Store

# Local config
.env

# Temporary files
*.tmp
*.bak
*~

# Claude Code local settings and agent worktrees
.claude/settings.local.json
.claude/worktrees/

# Build outputs
dist/
iliad_polylas/

# Rust
target/
.cargo/config.toml
